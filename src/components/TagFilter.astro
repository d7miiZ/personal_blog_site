---
interface Props {
  tags: string[];
  listSelector?: string;
}

const { tags, listSelector = '.filterable-list' } = Astro.props;
---

<div class="tag-filter" role="navigation" aria-label="Filter by tag" data-list-selector={listSelector}>
  <button class="filter-btn active" data-filter-tag="all">All</button>
  {tags.map((tag) => (
    <button class="filter-btn" data-filter-tag={tag}>{tag}</button>
  ))}
</div>

<p class="empty-msg" hidden>No items match this filter.</p>

<style>
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-sm);
    font-weight: 500;
    padding: 5px 14px;
    border-radius: var(--radius-full);
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    border: 1px solid var(--color-tag-border);
    cursor: pointer;
    transition: background-color var(--transition), color var(--transition), border-color var(--transition);
  }

  .filter-btn:hover,
  .filter-btn.active {
    background-color: var(--color-tag-active-bg);
    color: var(--color-tag-active-text);
    border-color: var(--color-tag-active-bg);
  }

  .empty-msg {
    color: var(--color-text-muted);
    font-style: italic;
    padding-block: var(--space-4);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.tag-filter').forEach((filter) => {
    const listSelector = filter.dataset.listSelector ?? '.filterable-list';
    const list = filter.closest('section, div.page-body, main')?.querySelector(listSelector)
      ?? document.querySelector(listSelector);
    const emptyMsg = filter.nextElementSibling as HTMLElement | null;

    filter.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        filter.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        const selected = btn.dataset.filterTag ?? 'all';
        const items = list?.querySelectorAll<HTMLElement>('[data-tags]') ?? [];
        let visible = 0;

        items.forEach((item) => {
          const itemTags = (item.dataset.tags ?? '').split(',').map((t) => t.trim());
          const show = selected === 'all' || itemTags.includes(selected);
          item.hidden = !show;
          if (show) visible++;
        });

        if (emptyMsg) emptyMsg.hidden = visible > 0;
      });
    });
  });
</script>
