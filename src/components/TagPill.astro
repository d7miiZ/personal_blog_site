---
interface Props {
  tag: string;
  href?: string;
  active?: boolean;
  size?: 'sm' | 'md';
}

const { tag, href, active = false, size = 'md' } = Astro.props;
const Tag = href ? 'a' : 'span';
---

<Tag
  href={href}
  class:list={['tag', `tag--${size}`, { 'tag--active': active }]}
>
  {tag}
</Tag>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-full);
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    border: 1px solid var(--color-tag-border);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--transition), color var(--transition), border-color var(--transition);
  }

  .tag--md {
    padding: 3px 10px;
  }

  .tag--sm {
    padding: 2px 8px;
    font-size: 0.7rem;
  }

  a.tag:hover,
  .tag--active {
    background-color: var(--color-tag-active-bg);
    color: var(--color-tag-active-text);
    border-color: var(--color-tag-active-bg);
    text-decoration: none;
  }
</style>
