---
import TagPill from './TagPill.astro';
import { link } from '../utils/url';

interface Props {
  title: string;
  description: string;
  slug: string;
  tags: string[];
  status: 'active' | 'archived' | 'wip';
  cover?: string;
  links?: {
    github?: string;
    live?: string;
    demo?: string;
  };
}

const { title, description, slug, tags, status, cover, links } = Astro.props;

const statusLabels: Record<string, string> = {
  active: 'Active',
  archived: 'Archived',
  wip: 'In Progress',
};
---

<article class="project-card">
  <a href={link(`/projects/${slug}`)} class="card-link" tabindex="-1" aria-hidden="true">
    {cover ? (
      <div class="cover">
        <img src={cover} alt={title} loading="lazy" />
      </div>
    ) : (
      <div class="cover cover--placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    )}
  </a>

  <div class="content">
    <div class="top-row">
      <span class:list={['status-badge', `status--${status}`]}>
        {statusLabels[status]}
      </span>
      <div class="ext-links">
        {links?.github && (
          <a href={links.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
          </a>
        )}
        {links?.live && (
          <a href={links.live} target="_blank" rel="noopener noreferrer" aria-label="Live site" title="Live site">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        )}
      </div>
    </div>

    <h2 class="title">
      <a href={link(`/projects/${slug}`)}>{title}</a>
    </h2>
    <p class="description">{description}</p>

    {tags.length > 0 && (
      <div class="tags">
        {tags.map((tag) => (
          <TagPill tag={tag} href={link(`/tags/${encodeURIComponent(tag)}`)} size="sm" />
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .project-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition), box-shadow var(--transition);
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
  }

  .project-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .card-link {
    display: block;
    text-decoration: none;
  }

  .cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-card:hover .cover img {
    transform: scale(1.03);
  }

  .cover--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-subtle);
  }

  .content {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }

  .status-badge {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }

  .status--active {
    background-color: #dcfce7;
    color: #166534;
  }

  .status--wip {
    background-color: #fef9c3;
    color: #854d0e;
  }

  .status--archived {
    background-color: var(--color-surface);
    color: var(--color-text-muted);
  }

  [data-theme="dark"] .status--active {
    background-color: #14532d;
    color: #86efac;
  }

  [data-theme="dark"] .status--wip {
    background-color: #713f12;
    color: #fde047;
  }

  .ext-links {
    display: flex;
    gap: var(--space-2);
  }

  .ext-links a {
    color: var(--color-text-muted);
    transition: color var(--transition);
    line-height: 0;
    text-decoration: none;
  }

  .ext-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .title {
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: var(--space-2);
  }

  .title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition);
  }

  .title a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-3);
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
  }
</style>
