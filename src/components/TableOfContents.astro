---
import type { MarkdownHeading } from 'astro';
import TocBranch from './TocBranch.astro';
import { buildTocTree } from '../utils/toc-tree';

interface Props {
  headings: MarkdownHeading[];
  minDepth?: number;
  maxDepth?: number;
}

const { headings, minDepth = 2, maxDepth = 4 } = Astro.props;

const filtered = headings.filter((h) => h.depth >= minDepth && h.depth <= maxDepth);
const tree = buildTocTree(filtered);
---

{
  tree.length > 0 && (
    <nav class="toc" data-toc-root aria-label="Table of contents">
      <div class="toc__accent" aria-hidden="true" />
      <div class="toc__inner">
        <div class="toc__header">
          <svg class="toc__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M4 6h16M4 12h10M4 18h14"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            />
          </svg>
          <p class="toc__label">On this page</p>
        </div>
        <div class="toc__body">
          <TocBranch nodes={tree} />
        </div>
      </div>
    </nav>
  )
}

<style is:global>
  .toc[data-toc-root] {
    position: relative;
    margin-bottom: var(--space-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--color-accent) 7%, var(--color-surface)) 0%,
      var(--color-surface) 48%,
      var(--color-surface) 100%
    );
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .toc__accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(
      180deg,
      var(--color-accent) 0%,
      color-mix(in srgb, var(--color-accent) 45%, transparent) 55%,
      transparent 100%
    );
    pointer-events: none;
  }

  .toc__inner {
    padding: var(--space-6) var(--space-6) var(--space-6) var(--space-8);
  }

  .toc__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .toc__icon {
    flex-shrink: 0;
    color: var(--color-accent);
    opacity: 0.9;
  }

  .toc__label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
    margin: 0;
  }

  .toc__body {
    max-height: min(70vh, 28rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    padding-right: var(--space-2);
    margin-right: calc(-1 * var(--space-2));
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .toc__body::-webkit-scrollbar {
    width: 6px;
  }

  .toc__body::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: var(--radius-full);
  }

  .toc[data-toc-root] .toc__branch {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .toc[data-toc-root] .toc__branch--nested {
    margin-top: var(--space-2);
    margin-left: var(--space-1);
    padding-left: var(--space-4);
    border-left: 2px solid color-mix(in srgb, var(--color-accent) 22%, var(--color-border));
    gap: var(--space-1);
  }

  .toc[data-toc-root] .toc__item {
    margin: 0;
  }

  .toc[data-toc-root] .toc__link {
    display: block;
    padding: var(--space-2) var(--space-3);
    margin: 0 calc(-1 * var(--space-3));
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    line-height: 1.45;
    transition:
      color var(--transition),
      background-color var(--transition),
      box-shadow var(--transition);
  }

  .toc[data-toc-root] .toc__item--d2 .toc__link {
    font-weight: 500;
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .toc[data-toc-root] .toc__item--d3 .toc__link,
  .toc[data-toc-root] .toc__item--d4 .toc__link {
    font-size: var(--text-sm);
    font-weight: 400;
  }

  .toc[data-toc-root] .toc__link:hover {
    color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 8%, transparent);
    text-decoration: none;
  }

  .toc[data-toc-root] .toc__link.is-active {
    color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-accent) 28%, transparent);
    font-weight: 600;
  }

  .toc[data-toc-root] .toc__item--d3 .toc__link.is-active,
  .toc[data-toc-root] .toc__item--d4 .toc__link.is-active {
    font-weight: 600;
  }

  @media (prefers-reduced-motion: reduce) {
    .toc[data-toc-root] .toc__link {
      transition: none;
    }
  }
</style>

<script>
  (function () {
    const root = document.querySelector('[data-toc-root]');
    const prose = document.querySelector('article .prose');
    if (!root || !prose) return;

    const links = [...root.querySelectorAll('a[data-toc-link]')];
    const headings = [...prose.querySelectorAll('h2[id], h3[id], h4[id]')];
    if (!headings.length || !links.length) return;

    const navVar = getComputedStyle(document.documentElement).getPropertyValue('--nav-height').trim();
    const navH = parseInt(navVar, 10) || 64;
    let ticking = false;

    function update() {
      let currentId = headings[0] ? headings[0].id : '';
      for (let i = 0; i < headings.length; i++) {
        if (headings[i].getBoundingClientRect().top <= navH + 12) {
          currentId = headings[i].id;
        }
      }
      const href = '#' + currentId;
      for (let j = 0; j < links.length; j++) {
        links[j].classList.toggle('is-active', links[j].getAttribute('href') === href);
      }
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>
