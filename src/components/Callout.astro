---
interface Props {
  variant?: 'info' | 'tip' | 'caution';
  title?: string;
}

const { variant = 'info', title } = Astro.props;
---

<aside class:list={['callout', `callout--${variant}`]} role="note">
  {title && <p class="callout__title">{title}</p>}
  <div class="callout__body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    margin-block: var(--space-6);
    padding: var(--space-6) var(--space-8);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    font-size: var(--text-sm);
    line-height: 1.65;
  }

  .callout__title {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
    margin: 0 0 var(--space-3);
    line-height: 1.4;
  }

  .callout__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout__body :global(p:first-child) {
    margin-top: 0;
  }

  .callout__body :global(p) {
    margin-bottom: 0.75em;
  }

  .callout--tip {
    border-color: var(--color-accent);
    background-color: var(--color-accent-subtle);
  }

  .callout--tip .callout__title {
    color: var(--color-accent);
  }

  .callout--caution {
    border-color: #ca8a04;
    background-color: color-mix(in srgb, #ca8a04 8%, var(--color-surface));
  }

  [data-theme='dark'] .callout--caution {
    border-color: #eab308;
    background-color: color-mix(in srgb, #eab308 12%, var(--color-surface));
  }
</style>
