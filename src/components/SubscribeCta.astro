---
interface Props {
  heading?: string;
  text?: string;
  compact?: boolean;
}

const {
  heading = 'Subscribe for updates',
  text = 'Get an email when I publish a new post or project.',
  compact = false,
} = Astro.props;

const formAction = import.meta.env.PUBLIC_BUTTONDOWN_ACTION_URL?.trim();
const hostedSubscribeUrl = import.meta.env.PUBLIC_SUBSCRIBE_URL?.trim();
const hasEmbeddedForm = Boolean(formAction);
const subscribeUrl =
  hostedSubscribeUrl || formAction || '';
const hasHostedLink = Boolean(subscribeUrl);
---

<section class:list={['subscribe-cta', { compact }]} aria-label="Newsletter subscription">
  <h2>{heading}</h2>
  <p>{text}</p>

  {hasEmbeddedForm ? (
    <form action={formAction} method="post" target="_blank">
      <label class="sr-only" for="subscriber-email">Email address</label>
      <input
        id="subscriber-email"
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        autocomplete="email"
      />
      <button type="submit">Subscribe</button>
    </form>
  ) : hasHostedLink ? (
    <a href={subscribeUrl} target="_blank" rel="noopener noreferrer" class="subscribe-link">
      Subscribe
    </a>
  ) : (
    <p class="subscribe-missing">
      Newsletter signup is not configured. Set{' '}
      <code>PUBLIC_BUTTONDOWN_ACTION_URL</code> at build time (see README).
    </p>
  )}

  <small>No spam. Unsubscribe anytime.</small>
</section>

<style>
  .subscribe-cta {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .subscribe-cta.compact {
    padding: var(--space-4);
  }

  h2 {
    font-size: var(--text-lg);
    font-weight: 600;
  }

  p {
    color: var(--color-text-muted);
    margin: 0;
  }

  form {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  input {
    flex: 1 1 220px;
    min-width: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.6rem 0.75rem;
    font: inherit;
    color: var(--color-text);
    background: var(--color-bg);
  }

  button,
  .subscribe-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 0.85rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-accent);
    background: var(--color-accent);
    color: #fff;
    font-weight: 600;
    text-decoration: none;
    transition: filter var(--transition);
    cursor: pointer;
  }

  button:hover,
  .subscribe-link:hover {
    filter: brightness(0.95);
    text-decoration: none;
  }

  small {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
  }

  .subscribe-missing {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .subscribe-missing code {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
</style>
